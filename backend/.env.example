# 数据库配置
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/kuaile8

# JWT配置
JWT_SECRET=your-jwt-secret-key-min-32-characters-long

# 彩票数据API
LOTTERY_API_ID=your-api-id
LOTTERY_API_KEY=your-api-key

# 支付配置
PAYMENT_API_URL=https://your-payment-api.com
PAYMENT_MERCHANT_ID=your-merchant-id
PAYMENT_KEY=your-payment-key

# 定时任务密钥
CRON_SECRET=your-cron-secret-key

# 环境标识
NODE_ENV=production
VERCEL=0
